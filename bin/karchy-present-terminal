#!/bin/bash
# Launch a floating centered Alacritty window running a command.
# Usage: karchy-present-terminal "command to run"

exec alacritty \
  --class "karchy-float,karchy-float" \
  --option "window.dimensions.columns=100" \
  --option "window.dimensions.lines=30" \
  -e bash -c "$1; echo; echo 'Press any key to close...'; read -rsn1"
