#!/bin/bash
# Launch a command as a fully detached process via systemd scope.
# Usage: karchy-detach <command> [args...]
# Uses --scope so the child inherits the caller's full environment
# (DISPLAY, WAYLAND_DISPLAY, DBUS_SESSION_BUS_ADDRESS, etc.)
# instead of running in systemd's clean service environment.
systemd-run --user --scope -- "$@" &>/dev/null &
