#!/bin/bash
# Launch a command as a fully detached process via systemd.
# Usage: karchy-detach <command> [args...]
# Passes essential session environment so GUI apps (VS Code, etc.) work.
env_args=()
for var in DISPLAY WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE \
           XDG_CURRENT_DESKTOP DBUS_SESSION_BUS_ADDRESS; do
  [[ -n "${!var}" ]] && env_args+=(--setenv="$var=${!var}")
done
exec systemd-run --user --no-block "${env_args[@]}" "$@" &>/dev/null
