#!/bin/bash
# Launch a command as a fully detached GUI process via systemd scope.
# Usage: karchy-detach <command> [args...]
#
# Uses --scope for proper KDE Plasma cgroup integration:
#   - Inherits the caller's full environment
#   - Gets its own scope under app.slice
#   - Scope survives after the launching terminal/script exits
systemd-run --user --scope -- "$@" &>/dev/null &
