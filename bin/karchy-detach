#!/bin/bash
# Launch a command as a fully detached GUI process.
# Usage: karchy-detach <command> [args...]
#
# Double-fork pattern: the subshell backgrounds the command and exits
# immediately, orphaning it so init/systemd adopts it. This survives
# terminal closure because the process is in no shell's job table and
# has no controlling terminal dependency.
( "$@" &>/dev/null & )
