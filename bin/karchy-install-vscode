#!/bin/bash
set -e
echo -e "\e[32mInstalling Visual Studio Code\e[0m"

karchy-pkg-aur-add visual-studio-code-bin
karchy-pkg-add gnome-keyring

# Use gnome-libsecret for credential storage
if command -v git &>/dev/null; then
  git config --global credential.helper /usr/lib/git-core/git-credential-libsecret 2>/dev/null || true
fi

# Disable auto-update (managed by pacman/paru)
VSCODE_SETTINGS="$HOME/.config/Code/User/settings.json"
if [[ ! -f $VSCODE_SETTINGS ]]; then
  mkdir -p "$(dirname "$VSCODE_SETTINGS")"
  echo '{"update.mode": "none"}' > "$VSCODE_SETTINGS"
elif ! grep -q '"update.mode"' "$VSCODE_SETTINGS"; then
  sed -i 's/^{/{\n  "update.mode": "none",/' "$VSCODE_SETTINGS"
fi

echo -e "\nLaunching VSCode..."
karchy-detach gtk-launch code
