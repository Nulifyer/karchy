#!/bin/bash
# Remove orphaned packages and clean the package cache.

echo -e '\e[32mRemoving orphaned packages...\e[0m'
orphans=$(pacman -Qdtq 2>/dev/null)
if [[ -n $orphans ]]; then
  echo "$orphans"
  echo ""
  echo "$orphans" | sudo pacman -Rns --noconfirm -
else
  echo "No orphaned packages found."
fi

echo ""
echo -e '\e[32mCleaning package cache...\e[0m'
sudo pacman -Sc --noconfirm

echo ""
echo "Done!"
