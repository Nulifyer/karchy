#!/bin/bash
# Launch a URL in webapp mode (standalone window without browser chrome).
# Tries Chromium-based browsers in preference order (open-source first),
# then falls back to xdg-open.

URL="$1"
CLASS="$2"
if [[ -z $URL ]]; then
  echo "Usage: karchy-webapp-launch <url> [class-name]"
  exit 1
fi

# Extract the Exec binary from a .desktop file
get_browser_exec() {
  local desktop_file
  for dir in /usr/share/applications "$HOME/.local/share/applications"; do
    if [[ -f "$dir/$1" ]]; then
      desktop_file="$dir/$1"
      break
    fi
  done
  [[ -z $desktop_file ]] && return 1
  grep -oP '^Exec=\K[^ %]+' "$desktop_file" | head -1
}

launch_app() {
  local exec="$1"
  local args=(--app="$URL")
  [[ -n $CLASS ]] && args+=(--class="$CLASS")
  exec "$exec" "${args[@]}"
}

# Preferred browser order: open-source first, then proprietary
BROWSERS=(
  brave-browser.desktop
  brave-browser-stable.desktop
  ungoogled-chromium.desktop
  chromium.desktop
  chromium-browser.desktop
  vivaldi-stable.desktop
  vivaldi.desktop
  opera.desktop
  google-chrome.desktop
  google-chrome-stable.desktop
)

for desktop in "${BROWSERS[@]}"; do
  exec_path=$(get_browser_exec "$desktop") && [[ -n $exec_path ]] && launch_app "$exec_path"
done

# Fallback: open as a regular page in the default browser
exec xdg-open "$URL"
