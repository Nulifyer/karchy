#!/bin/bash
# Reset karchy to match the remote, discarding any local changes.

INSTALL_DIR="$HOME/.local/share/karchy"

if [[ ! -d "$INSTALL_DIR/.git" ]]; then
  echo "Karchy install directory not found at $INSTALL_DIR"
  echo "Run the installer first."
  exit 1
fi

echo -e '\e[33mResetting karchy to latest remote state...\e[0m'
git -C "$INSTALL_DIR" fetch origin
git -C "$INSTALL_DIR" reset --hard origin/main
git -C "$INSTALL_DIR" clean -fd
chmod +x "$INSTALL_DIR/bin/"*

echo ""
echo -e '\e[32mKarchy reset to latest remote version.\e[0m'
