#!/bin/bash
# Theme picker for karchy — select a color theme or auto (KDE).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/karchy-colors"
source "$SCRIPT_DIR/karchy-themes"

THEME_FILE="$HOME/.config/karchy/theme"
CURRENT="auto"
[[ -f "$THEME_FILE" ]] && CURRENT=$(<"$THEME_FILE")

entries=()
while IFS= read -r name; do
  if [[ "$name" == "$CURRENT" ]]; then
    entries+=("● $name")
  else
    entries+=("  $name")
  fi
done < <(karchy_theme_list)

choice=$(printf '%s\n' "${entries[@]}" | fuzzel --dmenu \
  --prompt "Theme  " \
  --width 28 \
  --lines 12 \
  --inner-pad 12 \
  --horizontal-pad 20 \
  --border-width 2 \
  --border-radius 12 \
  --border-color "$KARCHY_ACCENT_FUZZEL" \
  --background "$KARCHY_BG_FUZZEL" \
  --text-color "$KARCHY_FG_FUZZEL" \
  --match-color "$KARCHY_ACCENT_FUZZEL" \
  --selection-color "$KARCHY_COLOR0_FUZZEL" \
  --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
  --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
  --prompt-color "$KARCHY_ACCENT_FUZZEL" \
  --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
  --font "CaskaydiaCove Nerd Font:size=13" \
  --line-height 24 \
  --letter-spacing 1)

[[ -z "$choice" ]] && exit 0

# Strip the bullet/spaces prefix
theme="${choice#● }"
theme="${theme#  }"

[[ "$theme" == "$CURRENT" ]] && exit 0

mkdir -p "$(dirname "$THEME_FILE")"
if [[ "$theme" == "auto" ]]; then
  rm -f "$THEME_FILE"
else
  echo "$theme" > "$THEME_FILE"
fi

echo "Theme set to: $theme"
echo "Reopen karchy menu to see new colors."
