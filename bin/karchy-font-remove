#!/bin/bash
# Interactive nerd font remover using fzf with multi-select.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/karchy-colors"
source "$SCRIPT_DIR/karchy-font-names"

fzf_colors=$(get_fzf_color_string)

entries=()
while IFS= read -r pkg; do
  name="${FONT_NAMES[$pkg]:-$pkg}"
  entries+=("$(printf '%-24s %s' "$name" "$pkg")")
done < <(pacman -Qqe 2>/dev/null | grep '.*-nerd$' | sort)

if [[ ${#entries[@]} -eq 0 ]]; then
  echo "No nerd fonts installed."
  exit 0
fi

selection=$(printf '%s\n' "${entries[@]}" | fzf \
  --multi \
  --prompt "Remove Fonts > " \
  --header "tab: multi-select | enter: remove" \
  --color "$fzf_colors" \
  --layout reverse --no-border \
  --color 'pointer:red,marker:red') || exit $?

# Extract package names (last field on each line)
pkg_names=$(echo "$selection" | awk '{print $NF}')

if [[ -n $pkg_names ]]; then
  echo "$pkg_names" | tr '\n' ' ' | xargs sudo pacman -Rns --noconfirm
  karchy-show-done
fi
