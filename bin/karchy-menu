}

# ── Install Menu ───────────────────────────────────────────────────────────
show_install_menu() {
  case $(menu "Install" \
    "$(entry "󰣇" "Package (pacman)")" \
    "$(entry "󰣇" "AUR (paru)")" \
    "$(entry "󰖟" "Web App")" \
    "$(entry "󰒍" "Service")" \
    "$(entry "󰅩" "Development")" \
    "$(entry "󰨞" "Editor")" \
    "$(entry "󰆍" "Terminal")" \
    "$(entry "󰚩" "AI")" \
    "$(entry "󰛖" "Font")" \
    "$(entry "󰊗" "Gaming")" \
  ) in
  *pacman*) karchy-present-terminal karchy-pkg-install 40 ;;
  *paru*) karchy-present-terminal karchy-pkg-aur-install 40 ;;
  *Web\ App*) present_terminal karchy-webapp-install ;;
  *Service*) show_install_service_menu ;;
  *Development*) show_install_dev_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Font*) show_install_font_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *) back_to show_main_menu ;;
  esac
}

