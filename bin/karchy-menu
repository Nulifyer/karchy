#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
source "$SCRIPT_DIR/karchy-colors"

BACK_TO_EXIT=false

back_to() {
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n ${1:-} ]]; then
    "$1"
  else
    show_main_menu
  fi
}

entry() {
  printf '%s %s' "$1" "$2"
}

menu() {
  local prompt="$1"
  shift
  printf '%s\n' "$@" | fuzzel --dmenu \
    --prompt "$prompt  " \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

fuzzel_apps() {
  fuzzel \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

present_terminal() {
  karchy-present-terminal "$1" "${2:-}"
}

# ── Install helpers ────────────────────────────────────────────────────────
install() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-add $2 && karchy-detach gtk-launch $3"
}

aur_install() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-aur-add $2 && karchy-detach gtk-launch $3"
}



# ── Learn Menu ─────────────────────────────────────────────────────────────
show_learn_menu() {
  case $(menu "Learn" \
    "$(entry $'\uf030c' "Keybindings")" \
    "$(entry $'\ue86c' "KDE Plasma")" \
    "$(entry $'\ue732' "Arch Wiki")" \
    "$(entry $'\ue760' "Bash")" \
  ) in
  *Keybindings*) kcmshell6 kcm_keys & ;;
  *KDE*) xdg-open "https://userbase.kde.org/Plasma" & ;;
  *Arch*) xdg-open "https://wiki.archlinux.org" & ;;
  *Bash*) xdg-open "https://devhints.io/bash" & ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Update > Hardware Submenu ──────────────────────────────────────────────
show_update_hardware_menu() {
  case $(menu "Hardware" \
    "$(entry $'\uf0d7e' "Restart Audio")" \
    "$(entry $'\uf05a9' "Restart Wi-Fi")" \
    "$(entry $'\uf00af' "Restart Bluetooth")" \
  ) in
  *Audio*) present_terminal "systemctl --user restart pipewire pipewire-pulse wireplumber && echo 'Audio restarted.'" ;;
  *Wi-Fi*) present_terminal "sudo rfkill unblock wifi && sudo systemctl restart NetworkManager && echo 'Wi-Fi restarted.'" ;;
  *Bluetooth*) present_terminal "sudo rfkill unblock bluetooth && sudo systemctl restart bluetooth && echo 'Bluetooth restarted.'" ;;
  *) back_to show_update_menu ;;
  esac
}

# ── Update Menu ────────────────────────────────────────────────────────────
show_update_menu() {
  case $(menu "Update" \
    "$(entry $'\uf06b0' "System Update")" \
    "$(entry $'\uea69' "Mirror Ranking")" \
    "$(entry $'\uf08ce' "Package Cache Clean")" \
    "$(entry $'\ueb53' "Firmware")" \
    "$(entry $'\uf07f5' "Password")" \
    "$(entry $'\uf0694' "Timezone")" \
    "$(entry $'\ueaf8' "Hardware")" \
  ) in
  *System\ Update*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Cache*) present_terminal "sudo pacman -Scc" ;;
  *Firmware*) present_terminal karchy-update-firmware ;;
  *Password*) present_terminal passwd ;;
  *Timezone*) present_terminal karchy-tz-select ;;
  *Hardware*) show_update_hardware_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Setup > Power Profile Submenu ─────────────────────────────────────────
show_setup_power_menu() {
  local profiles
  profiles=$(powerprofilesctl list 2>/dev/null | grep -oP '^\s*\*?\s*\K[a-z][-a-z]*(?=:\s*$)') || {
    present_terminal "echo 'power-profiles-daemon not available.'"
    return
  }

  if [[ -z $profiles ]]; then
    present_terminal "echo 'No power profiles found.'"
    return
  fi

  local entries=()
  while IFS= read -r p; do
    entries+=("$(entry $'\uf06a5' "$p")")
  done <<< "$profiles"

  local choice
  choice=$(menu "Power" "${entries[@]}") || { back_to show_setup_menu; return; }
  local profile="${choice#* }"
  present_terminal "powerprofilesctl set '$profile' && echo 'Power profile set to $profile'"
}

# ── Setup Menu ─────────────────────────────────────────────────────────────
show_setup_menu() {
  case $(menu "Setup" \
    "$(entry $'\uf0d7e' "Audio")" \
    "$(entry $'\uf05a9' "Wifi")" \
    "$(entry $'\uf00af' "Bluetooth")" \
    "$(entry $'\uf0379' "Monitors")" \
    "$(entry $'\uf06a5' "Power Profile")" \
    "$(entry $'\ueb53' "DNS")" \
    "$(entry $'\ueada' "Screenshot")" \
    "$(entry $'\uf0218' "Theme")" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) kcmshell6 kcm_networkmanagement & ;;
  *Bluetooth*) kcmshell6 kcm_bluetooth & ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *Power*) show_setup_power_menu ;;
  *DNS*) present_terminal karchy-setup-dns ;;
  *Screenshot*) spectacle & ;;
  *Theme*) karchy-theme-select && source "$SCRIPT_DIR/karchy-colors" && show_main_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Install > Service Submenu ─────────────────────────────────────────────
show_install_service_menu() {
  case $(menu "Service" \
    "$(entry $'\ueb53' "Tailscale")" \
    "$(entry $'\ueb11' "Bitwarden")" \
    "$(entry $'\ueb53' "NordVPN")" \
    "$(entry $'\uf16b' "Dropbox")" \
  ) in
  *Tailscale*) present_terminal karchy-install-tailscale ;;
  *Bitwarden*) install_and_launch "Bitwarden" bitwarden bitwarden ;;
  *NordVPN*) present_terminal karchy-install-nordvpn ;;
  *Dropbox*) present_terminal karchy-install-dropbox ;;
  *) back_to show_install_menu ;;
  esac
}

