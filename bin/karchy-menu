#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
source "$SCRIPT_DIR/karchy-colors"

BACK_TO_EXIT=false

back_to() {
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n ${1:-} ]]; then
    "$1"
  else
    show_main_menu
  fi
}

entry() {
  printf '%s %s' "$1" "$2"
}

menu() {
  local prompt="$1"
  shift
  printf '%s\n' "$@" | fuzzel --dmenu \
    --prompt "$prompt  " \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

fuzzel_apps() {
  fuzzel \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

present_terminal() {
  karchy-present-terminal "$1" "${2:-}"
}

# ── Update > Hardware Submenu ──────────────────────────────────────────────
show_update_hardware_menu() {
  case $(menu "Hardware" \
    "$(entry $'\U000f0d7e' "Restart Audio")" \
    "$(entry $'\U000f05a9' "Restart Wi-Fi")" \
    "$(entry $'\U000f00af' "Restart Bluetooth")" \
  ) in
  *Audio*) present_terminal "systemctl --user restart pipewire pipewire-pulse wireplumber && echo 'Audio restarted.'" ;;
  *Wi-Fi*) present_terminal "sudo rfkill unblock wifi && sudo systemctl restart NetworkManager && echo 'Wi-Fi restarted.'" ;;
  *Bluetooth*) present_terminal "sudo rfkill unblock bluetooth && sudo systemctl restart bluetooth && echo 'Bluetooth restarted.'" ;;
  *) back_to show_update_menu ;;
  esac
}

# ── Update Menu ────────────────────────────────────────────────────────────
show_update_menu() {
  case $(menu "Update" \
    "$(entry $'\U000f06b0' "System Update")" \
    "$(entry $'\uea69' "Mirror Ranking")" \
    "$(entry $'\ueb53' "Firmware")" \
    "$(entry $'\U000f0694' "Timezone")" \
    "$(entry $'\ueaf8' "Hardware")" \
    "$(entry $'\U000f04bb' "Cleanup")" \
    "$(entry $'\U000f06b0' "Update Karchy")" \
  ) in
  *System\ Update*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Firmware*) present_terminal karchy-update-firmware ;;
  *Timezone*) present_terminal karchy-tz-select ;;
  *Hardware*) show_update_hardware_menu ;;
  *Cleanup*) present_terminal karchy-pkg-cleanup ;;
  *Karchy*) present_terminal karchy-self-update ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Setup > Power Profile Submenu ─────────────────────────────────────────
show_setup_power_menu() {
  local profiles
  profiles=$(powerprofilesctl list 2>/dev/null | grep -oP '^\s*\*?\s*\K[a-z][-a-z]*(?=:\s*$)') || {
    present_terminal "echo 'power-profiles-daemon not available.'"
    return
  }

  if [[ -z $profiles ]]; then
    present_terminal "echo 'No power profiles found.'"
    return
  fi

  local entries=()
  while IFS= read -r p; do
    entries+=("$(entry $'\U000f06a5' "$p")")
  done <<< "$profiles"

  local choice
  choice=$(menu "Power" "${entries[@]}") || { back_to show_setup_menu; return; }
  local profile="${choice#* }"
  present_terminal "powerprofilesctl set '$profile' && echo 'Power profile set to $profile'"
}

# ── Setup Menu ─────────────────────────────────────────────────────────────
show_setup_menu() {
  case $(menu "Setup" \
    "$(entry $'\U000f0d7e' "Audio")" \
    "$(entry $'\U000f05a9' "Wifi")" \
    "$(entry $'\U000f00af' "Bluetooth")" \
    "$(entry $'\U000f0379' "Monitors")" \
    "$(entry $'\U000f06a5' "Power Profile")" \
    "$(entry $'\U000f0218' "Theme")" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) kcmshell6 kcm_networkmanagement & ;;
  *Bluetooth*) kcmshell6 kcm_bluetooth & ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *Power*) show_setup_power_menu ;;
  *Theme*) karchy-theme-select && source "$SCRIPT_DIR/karchy-colors" && show_main_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Install Menu ───────────────────────────────────────────────────────────
show_install_menu() {
  case $(menu "Install" \
    "$(entry $'\U000f08ce' "Package (pacman)")" \
    "$(entry $'\U000f08ce' "AUR (paru)")" \
    "$(entry $'\U000f059f' "Web App")" \
    "$(entry $'\U000f06d6' "Font")" \
  ) in
  *pacman*) karchy-present-terminal karchy-pkg-install 40 ;;
  *paru*) karchy-present-terminal karchy-pkg-aur-install 40 ;;
  *Web\ App*) present_terminal karchy-webapp-install ;;
  *Font*) karchy-present-terminal karchy-font-install 40 ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Remove Menu ────────────────────────────────────────────────────────────
show_remove_menu() {
  case $(menu "Remove" \
    "$(entry $'\U000f08ce' "Package")" \
    "$(entry $'\U000f059f' "Web App")" \
    "$(entry $'\U000f06d6' "Font")" \
  ) in
  *Package*) karchy-present-terminal karchy-pkg-remove 40 ;;
  *Web\ App*) present_terminal karchy-webapp-remove ;;
  *Font*) karchy-present-terminal karchy-font-remove 40 ;;
  *) back_to show_main_menu ;;
  esac
}

# ── System Menu ────────────────────────────────────────────────────────────
show_system_menu() {
  local entries=(
    "$(entry $'\U000f033e' "Lock")"
    "$(entry $'\U000f04b2' "Suspend")"
  )

  # Add Hibernate if swap is available
  local swap_total
  swap_total=$(awk '/SwapTotal/{print $2}' /proc/meminfo)
  if (( swap_total > 0 )); then
    entries+=("$(entry $'\U000f0904' "Hibernate")")
  fi

  entries+=(
    "$(entry $'\U000f0343' "Logout")"
    "$(entry $'\U000f0709' "Restart")"
    "$(entry $'\U000f0425' "Shutdown")"
  )

  case $(menu "System" "${entries[@]}") in
  *Lock*) loginctl lock-session ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) qdbus6 org.kde.Shutdown /Shutdown logout ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Main Menu ──────────────────────────────────────────────────────────────
show_main_menu() {
  local commit
  commit=$(git -C "$HOME/.local/share/karchy" rev-parse --short HEAD 2>/dev/null)
  case $(menu "Karchy" \
    "$(entry $'\U000f003b' "Apps")" \
    "$(entry $'\U000f04bb' "Projects")" \
    "$(entry $'\ueaf8' "Setup")" \
    "$(entry $'\uf019' "Install")" \
    "$(entry $'\uea81' "Remove")" \
    "$(entry $'\U000f06b0' "Update")" \
    "$(entry $'\U000f0322' "System")" \
  ) in
  *Apps*) fuzzel_apps ;;
  *Projects*) karchy-present-terminal karchy-project-open 30 --no-padding ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *Remove*) show_remove_menu ;;
  *Update*) show_update_menu ;;
  *System*) show_system_menu ;;
  esac
}

# ── Entry point ────────────────────────────────────────────────────────────
if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  case "${1,,}" in
    apps) fuzzel_apps ;;
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    remove) show_remove_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
