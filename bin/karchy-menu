}

# ── System Menu ────────────────────────────────────────────────────────────
show_system_menu() {
  local entries=(
    "$(entry $'\uf033e' "Lock")"
    "$(entry $'\uf04b2' "Suspend")"
  )

  # Add Hibernate if swap is available
  local swap_total
  swap_total=$(awk '/SwapTotal/{print $2}' /proc/meminfo)
  if (( swap_total > 0 )); then
    entries+=("$(entry $'\uf0904' "Hibernate")")
  fi

  entries+=(
    "$(entry $'\uf0343' "Logout")"
    "$(entry $'\uf0709' "Restart")"
    "$(entry $'\uf0425' "Shutdown")"
  )

  case $(menu "System" "${entries[@]}") in
  *Lock*) loginctl lock-session ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) qdbus6 org.kde.Shutdown /Shutdown logout ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Main Menu ──────────────────────────────────────────────────────────────
show_main_menu() {
  case $(menu "Karchy" \
    "$(entry $'\uf003b' "Apps")" \
    "$(entry $'\uf04bb' "Projects")" \
    "$(entry $'\uf00ba' "Learn")" \
    "$(entry $'\ueaf8' "Setup")" \
    "$(entry $'\uf019' "Install")" \
    "$(entry $'\uea81' "Remove")" \
    "$(entry $'\uf06b0' "Update")" \
    "$(entry $'\uf0322' "System")" \
  ) in
  *Apps*) fuzzel_apps ;;
  *Projects*) karchy-present-terminal karchy-project-open 30 --no-padding ;;
  *Learn*) show_learn_menu ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *Remove*) show_remove_menu ;;
  *Update*) show_update_menu ;;
  *System*) show_system_menu ;;
  esac
}

# ── Entry point ────────────────────────────────────────────────────────────
if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  case "${1,,}" in
    apps) fuzzel_apps ;;
    learn) show_learn_menu ;;
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    remove) show_remove_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
