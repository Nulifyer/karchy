#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"

BACK_TO_EXIT=false

back_to() {
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n ${1:-} ]]; then
    "$1"
  else
    show_main_menu
  fi
}

entry() {
  printf '%s %s' "$1" "$2"
}

menu() {
  local prompt="$1"
  shift
  printf '%s\n' "$@" | fuzzel --dmenu \
    --prompt "$prompt  " \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color 89b4faff \
    --background 1e1e2eee \
    --text-color cdd6f4ff \
    --match-color 89b4faff \
    --selection-color 313244ff \
    --selection-text-color 89b4faff \
    --selection-match-color 74c7ecff \
    --prompt-color 89b4faff \
    --placeholder-color 6c7086ff \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

present_terminal() {
  karchy-present-terminal "$1"
}

# ── Update Menu ─────────────────────────────────────────────────────────────
show_update_menu() {
  case $(menu "Update" \
    "$(entry "󰚰" "System Update")" \
    "$(entry "󰒋" "Mirror Ranking")" \
    "$(entry "󰃢" "Package Cache Clean")" \
  ) in
  *System*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Cache*) present_terminal "sudo pacman -Scc" ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Setup Menu ──────────────────────────────────────────────────────────────
show_setup_menu() {
  case $(menu "Setup" \
    "$(entry "󰕾" "Audio")" \
    "$(entry "󰖩" "Wifi")" \
    "$(entry "󰂯" "Bluetooth")" \
    "$(entry "󰍹" "Monitors")" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) present_terminal gazelle ;;
  *Bluetooth*) kcmshell6 kcm_bluetooth & ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Install Menu ────────────────────────────────────────────────────────────
show_install_menu() {
  case $(menu "Install" \
    "$(entry "󰣇" "Package (pacman)")" \
    "$(entry "󰣇" "AUR (paru)")" \
  ) in
  *pacman*) present_terminal "sudo pacman -S" ;;
  *paru*) present_terminal "paru" ;;
  *) back_to show_main_menu ;;
  esac
}

# ── System Menu ─────────────────────────────────────────────────────────────
show_system_menu() {
  case $(menu "System" \
    "$(entry "󰌾" "Lock")" \
    "$(entry "󰒲" "Suspend")" \
    "$(entry "󰍃" "Logout")" \
    "$(entry "󰜉" "Restart")" \
    "$(entry "󰐥" "Shutdown")" \
  ) in
  *Lock*) loginctl lock-session ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) qdbus6 org.kde.ksmserver /KSMServer logout 0 0 0 ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Main Menu ───────────────────────────────────────────────────────────────
show_main_menu() {
  case $(menu "Karchy" \
    "$(entry "󰀻" "Apps")" \
    "$(entry "󰚰" "Update")" \
    "$(entry "󰒓" "Setup")" \
    "$(entry "󰉉" "Install")" \
    "$(entry "󰌢" "System")" \
  ) in
  *Apps*) fuzzel \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color 89b4faff \
    --background 1e1e2eee \
    --text-color cdd6f4ff \
    --match-color 89b4faff \
    --selection-color 313244ff \
    --selection-text-color 89b4faff \
    --selection-match-color 74c7ecff \
    --prompt-color 89b4faff \
    --placeholder-color 6c7086ff \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1 ;;
  *Update*) show_update_menu ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *System*) show_system_menu ;;
  esac
}

# ── Entry point ─────────────────────────────────────────────────────────────
if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  case "${1,,}" in
    apps) fuzzel \
      --width 32 --lines 10 --inner-pad 12 --horizontal-pad 20 \
      --border-width 2 --border-radius 12 --border-color 89b4faff \
      --background 1e1e2eee --text-color cdd6f4ff --match-color 89b4faff \
      --selection-color 313244ff --selection-text-color 89b4faff \
      --selection-match-color 74c7ecff --prompt-color 89b4faff \
      --placeholder-color 6c7086ff --font "CaskaydiaCove Nerd Font:size=13" \
      --line-height 24 --letter-spacing 1 ;;
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
