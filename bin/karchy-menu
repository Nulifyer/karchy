#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"

menu() {
  local prompt="$1"
  shift
  printf '%s\n' "$@" | fuzzel --dmenu --prompt "$prompt> " --width 30 --lines 10
}

present_terminal() {
  karchy-present-terminal "$1"
}

show_update_menu() {
  case $(menu "Update" \
    "  System Update" \
    "  Mirror Ranking" \
    "  Package Cache Clean" \
  ) in
  *System*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Cache*) present_terminal "sudo pacman -Scc" ;;
  *) show_main_menu ;;
  esac
}

show_system_menu() {
  case $(menu "System" \
    "  Lock" \
    "󰍃  Logout" \
    "󰜉  Restart" \
    "󰐥  Shutdown" \
  ) in
  *Lock*) loginctl lock-session ;;
  *Logout*) qdbus org.kde.ksmserver /KSMServer logout 0 0 0 ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) show_main_menu ;;
  esac
}

show_setup_menu() {
  case $(menu "Setup" \
    "  Audio" \
    "  Wifi" \
    "󰂯  Bluetooth" \
    "󰍹  Monitors" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) present_terminal nmtui ;;
  *Bluetooth*) present_terminal bluetuith ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *) show_main_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" \
    "󰣇  Package (pacman)" \
    "󰣇  AUR (paru)" \
  ) in
  *pacman*) present_terminal "sudo pacman -S" ;;
  *paru*) present_terminal "paru" ;;
  *) show_main_menu ;;
  esac
}

show_main_menu() {
  case $(menu "Karchy" \
    "  Update" \
    "  Setup" \
    "󰉉  Install" \
    "  System" \
  ) in
  *Update*) show_update_menu ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *System*) show_system_menu ;;
  esac
}

if [[ -n ${1:-} ]]; then
  case "${1,,}" in
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
