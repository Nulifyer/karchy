#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
source "$SCRIPT_DIR/karchy-colors"

BACK_TO_EXIT=false

back_to() {
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n ${1:-} ]]; then
    "$1"
  else
    show_main_menu
  fi
}

entry() {
  printf '%s %s' "$1" "$2"
}

menu() {
  local prompt="$1"
  shift
  printf '%s\n' "$@" | fuzzel --dmenu \
    --prompt "$prompt  " \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

fuzzel_apps() {
  fuzzel \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

present_terminal() {
  karchy-present-terminal "$1"
}

# ── Update Menu ─────────────────────────────────────────────────────────────
show_update_menu() {
  case $(menu "Update" \
    "$(entry "󰚰" "System Update")" \
    "$(entry "󰒋" "Mirror Ranking")" \
    "$(entry "󰃢" "Package Cache Clean")" \
  ) in
  *System*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Cache*) present_terminal "sudo pacman -Scc" ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Setup Menu ──────────────────────────────────────────────────────────────
show_setup_menu() {
  case $(menu "Setup" \
    "$(entry "󰕾" "Audio")" \
    "$(entry "󰖩" "Wifi")" \
    "$(entry "󰂯" "Bluetooth")" \
    "$(entry "󰍹" "Monitors")" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) kcmshell6 kcm_networkmanagement & ;;
  *Bluetooth*) kcmshell6 kcm_bluetooth & ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Install Menu ────────────────────────────────────────────────────────────
show_install_menu() {
  case $(menu "Install" \
    "$(entry "󰣇" "Package (pacman)")" \
    "$(entry "󰣇" "AUR (paru)")" \
  ) in
  *pacman*) karchy-present-terminal karchy-pkg-install 40 ;;
  *paru*) karchy-present-terminal karchy-pkg-aur-install 40 ;;
  *) back_to show_main_menu ;;
  esac
}

# ── System Menu ─────────────────────────────────────────────────────────────
show_system_menu() {
  case $(menu "System" \
    "$(entry "󰌾" "Lock")" \
    "$(entry "󰒲" "Suspend")" \
    "$(entry "󰍃" "Logout")" \
    "$(entry "󰜉" "Restart")" \
    "$(entry "󰐥" "Shutdown")" \
  ) in
  *Lock*) loginctl lock-session ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) qdbus6 org.kde.ksmserver /KSMServer logout 0 0 0 ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Main Menu ───────────────────────────────────────────────────────────────
show_main_menu() {
  case $(menu "Karchy" \
    "$(entry "󰀻" "Apps")" \
    "$(entry "󰚰" "Update")" \
    "$(entry "󰒓" "Setup")" \
    "$(entry "󰉉" "Install")" \
    "$(entry "󰌢" "System")" \
  ) in
  *Apps*) fuzzel_apps ;;
  *Update*) show_update_menu ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *System*) show_system_menu ;;
  esac
}

# ── Entry point ─────────────────────────────────────────────────────────────
if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  case "${1,,}" in
    apps) fuzzel_apps ;;
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
