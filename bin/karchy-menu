#!/bin/bash
# Karchy menu — omarchy-inspired launcher for KDE Plasma + fuzzel

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
source "$SCRIPT_DIR/karchy-colors"

BACK_TO_EXIT=false

back_to() {
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n ${1:-} ]]; then
    "$1"
  else
    show_main_menu
  fi
}

entry() {
  printf '%s %s' "$1" "$2"
}

menu() {
  local prompt="$1"
  local width=32
  shift
  if [[ "$1" == --width ]]; then
    width="$2"
    shift 2
  fi
  printf '%s\n' "$@" | fuzzel --dmenu \
    --prompt "$prompt  " \
    --width "$width" \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

fuzzel_apps() {
  fuzzel \
    --width 32 \
    --lines 10 \
    --inner-pad 12 \
    --horizontal-pad 20 \
    --border-width 2 \
    --border-radius 12 \
    --border-color "$KARCHY_ACCENT_FUZZEL" \
    --background "$KARCHY_BG_FUZZEL" \
    --text-color "$KARCHY_FG_FUZZEL" \
    --match-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-color "$KARCHY_COLOR0_FUZZEL" \
    --selection-text-color "$KARCHY_ACCENT_FUZZEL" \
    --selection-match-color "$KARCHY_COLOR6_FUZZEL" \
    --prompt-color "$KARCHY_ACCENT_FUZZEL" \
    --placeholder-color "$KARCHY_COLOR7_FUZZEL" \
    --font "CaskaydiaCove Nerd Font:size=13" \
    --line-height 24 \
    --letter-spacing 1
}

present_terminal() {
  karchy-present-terminal "$1" "${2:-}"
}

# ── Install helpers ────────────────────────────────────────────────────────
install() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-add $2 && karchy-detach gtk-launch $3"
}

aur_install() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo -e '\e[32mInstalling $1...\e[0m'; karchy-pkg-aur-add $2 && karchy-detach gtk-launch $3"
}

# ── Learn Menu ─────────────────────────────────────────────────────────────
show_learn_menu() {
  case $(menu "Learn" \
    "$(entry $'\U000f030c' "Keybindings")" \
    "$(entry $'\ue86c' "KDE Plasma")" \
    "$(entry $'\ue732' "Arch Wiki")" \
    "$(entry $'\ue760' "Bash")" \
  ) in
  *Keybindings*) kcmshell6 kcm_keys & ;;
  *KDE*) xdg-open "https://userbase.kde.org/Plasma" & ;;
  *Arch*) xdg-open "https://wiki.archlinux.org" & ;;
  *Bash*) xdg-open "https://devhints.io/bash" & ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Update > Hardware Submenu ──────────────────────────────────────────────
show_update_hardware_menu() {
  case $(menu "Hardware" \
    "$(entry $'\U000f0d7e' "Restart Audio")" \
    "$(entry $'\U000f05a9' "Restart Wi-Fi")" \
    "$(entry $'\U000f00af' "Restart Bluetooth")" \
  ) in
  *Audio*) present_terminal "systemctl --user restart pipewire pipewire-pulse wireplumber && echo 'Audio restarted.'" ;;
  *Wi-Fi*) present_terminal "sudo rfkill unblock wifi && sudo systemctl restart NetworkManager && echo 'Wi-Fi restarted.'" ;;
  *Bluetooth*) present_terminal "sudo rfkill unblock bluetooth && sudo systemctl restart bluetooth && echo 'Bluetooth restarted.'" ;;
  *) back_to show_update_menu ;;
  esac
}

# ── Update Menu ────────────────────────────────────────────────────────────
show_update_menu() {
  case $(menu "Update" \
    "$(entry $'\U000f06b0' "System Update")" \
    "$(entry $'\uea69' "Mirror Ranking")" \
    "$(entry $'\U000f08ce' "Package Cache Clean")" \
    "$(entry $'\ueb53' "Firmware")" \
    "$(entry $'\U000f07f5' "Password")" \
    "$(entry $'\U000f0694' "Timezone")" \
    "$(entry $'\ueaf8' "Hardware")" \
  ) in
  *System\ Update*) present_terminal karchy-update ;;
  *Mirror*) present_terminal "sudo cachyos-rate-mirrors" ;;
  *Cache*) present_terminal "sudo pacman -Scc" ;;
  *Firmware*) present_terminal karchy-update-firmware ;;
  *Password*) present_terminal passwd ;;
  *Timezone*) present_terminal karchy-tz-select ;;
  *Hardware*) show_update_hardware_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Setup > Power Profile Submenu ─────────────────────────────────────────
show_setup_power_menu() {
  local profiles
  profiles=$(powerprofilesctl list 2>/dev/null | grep -oP '^\s*\*?\s*\K[a-z][-a-z]*(?=:\s*$)') || {
    present_terminal "echo 'power-profiles-daemon not available.'"
    return
  }

  if [[ -z $profiles ]]; then
    present_terminal "echo 'No power profiles found.'"
    return
  fi

  local entries=()
  while IFS= read -r p; do
    entries+=("$(entry $'\U000f06a5' "$p")")
  done <<< "$profiles"

  local choice
  choice=$(menu "Power" "${entries[@]}") || { back_to show_setup_menu; return; }
  local profile="${choice#* }"
  present_terminal "powerprofilesctl set '$profile' && echo 'Power profile set to $profile'"
}

# ── Setup Menu ─────────────────────────────────────────────────────────────
show_setup_menu() {
  case $(menu "Setup" \
    "$(entry $'\U000f0d7e' "Audio")" \
    "$(entry $'\U000f05a9' "Wifi")" \
    "$(entry $'\U000f00af' "Bluetooth")" \
    "$(entry $'\U000f0379' "Monitors")" \
    "$(entry $'\U000f06a5' "Power Profile")" \
    "$(entry $'\ueb53' "DNS")" \
    "$(entry $'\ueada' "Screenshot")" \
    "$(entry $'\U000f0218' "Theme")" \
  ) in
  *Audio*) pavucontrol & ;;
  *Wifi*) kcmshell6 kcm_networkmanagement & ;;
  *Bluetooth*) kcmshell6 kcm_bluetooth & ;;
  *Monitors*) kcmshell6 kcm_kscreen & ;;
  *Power*) show_setup_power_menu ;;
  *DNS*) present_terminal karchy-setup-dns ;;
  *Screenshot*) spectacle & ;;
  *Theme*) karchy-theme-select && source "$SCRIPT_DIR/karchy-colors" && show_main_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Install > .NET Submenu ────────────────────────────────────────────────
show_install_dotnet_menu() {
  local icon=$'\ue77f'
  local -A ver_map=() pkg_map=()
  while IFS= read -r line; do
    local repo_pkg ver pkg major
    repo_pkg="${line%% *}"
    ver="${line#* }"; ver="${ver%% *}"
    pkg="${repo_pkg##*/}"
    major="${ver%%.*}"
    if [[ -z ${ver_map[$major]+x} ]]; then
      ver_map[$major]="$ver"
      pkg_map[$major]="$pkg"
    fi
  done < <(pacman -Ss '^dotnet-sdk' 2>/dev/null | grep -v '^ ' | sort -t' ' -k2 -rV)

  if [[ ${#ver_map[@]} -eq 0 ]]; then
    present_terminal "echo 'No .NET SDK packages found in repositories.'"
    return
  fi

  local -a labels=() majors=()
  while IFS= read -r m; do
    majors+=("$m")
    labels+=("$(entry "$icon" ".NET $m SDK (${ver_map[$m]}) — ${pkg_map[$m]}")")
  done < <(printf '%s\n' "${!ver_map[@]}" | sort -rn)

  local choice
  choice=$(menu ".NET (dotnet)" --width 48 "${labels[@]}") || { back_to show_install_menu; return; }
  local i
  for i in "${!labels[@]}"; do
    if [[ "${labels[$i]}" == "$choice" ]]; then
      present_terminal "echo -e '\e[32mInstalling .NET ${majors[$i]} SDK...\e[0m'; karchy-pkg-add '${pkg_map[${majors[$i]}]}'"
      return
    fi
  done
}

# ── Install > Java Submenu ────────────────────────────────────────────────
show_install_java_menu() {
  local choice
  choice=$(menu "Java" \
    "$(entry $'\ue738' "JDK (Development Kit)")" \
    "$(entry $'\ue738' "JRE (Runtime)")" \
  ) || { back_to show_featured_menu; return; }

  local type prefix
  if [[ $choice == *JDK* ]]; then
    type="JDK"; prefix="jdk"
  else
    type="JRE"; prefix="jre"
  fi

  local icon=$'\ue738'
  local -A ver_map=() pkg_map=()
  while IFS= read -r line; do
    local repo_pkg ver pkg major
    repo_pkg="${line%% *}"
    ver="${line#* }"; ver="${ver%% *}"
    pkg="${repo_pkg##*/}"
    # Extract major version from package name (jdk17-openjdk -> 17, jdk-openjdk -> latest)
    local num="${pkg#${prefix}}"
    num="${num%%-*}"
    if [[ -z $num ]]; then
      major="${ver%%.*}"
    else
      major="$num"
    fi
    # Skip headless/doc/src/debug variants
    [[ $pkg == *-headless* || $pkg == *-doc* || $pkg == *-src* || $pkg == *-debug* ]] && continue
    if [[ -z ${ver_map[$major]+x} ]]; then
      ver_map[$major]="$ver"
      pkg_map[$major]="$pkg"
    fi
  done < <(pacman -Ss "^${prefix}[0-9]*-openjdk\$\|^${prefix}-openjdk\$" 2>/dev/null | grep -v '^ ' | sort -t' ' -k2 -rV)

  if [[ ${#ver_map[@]} -eq 0 ]]; then
    present_terminal "echo 'No OpenJDK $type packages found in repositories.'"
    return
  fi

  local -a labels=() majors=()
  while IFS= read -r m; do
    majors+=("$m")
    labels+=("$(entry "$icon" "OpenJDK $m $type (${ver_map[$m]}) — ${pkg_map[$m]}")")
  done < <(printf '%s\n' "${!ver_map[@]}" | sort -rn)

  local pick
  pick=$(menu "Java $type" --width 48 "${labels[@]}") || { show_install_java_menu; return; }
  local i
  for i in "${!labels[@]}"; do
    if [[ "${labels[$i]}" == "$pick" ]]; then
      present_terminal "echo -e '\e[32mInstalling OpenJDK ${majors[$i]} $type...\e[0m'; karchy-pkg-add '${pkg_map[${majors[$i]}]}'"
      return
    fi
  done
}

# ── Install > Featured Menu ──────────────────────────────────────────────
show_featured_menu() {
  local choice
  choice=$(menu "Featured" --width 36 \
    "$(entry $'\ue8da' "VSCode")" \
    "$(entry $'\uea73' "Cursor")" \
    "$(entry $'\uea73' "Zed")" \
    "$(entry $'\ue7aa' "Sublime Text")" \
    "$(entry $'\uea73' "Helix")" \
    "$(entry $'\ue7cf' "Emacs")" \
    "$(entry $'\uea85' "Alacritty")" \
    "$(entry $'\uea85' "Ghostty")" \
    "$(entry $'\uea85' "Kitty")" \
    "$(entry $'\uec10' "Claude Code")" \
    "$(entry $'\uec10' "Codex")" \
    "$(entry $'\uec10' "Gemini CLI")" \
    "$(entry $'\uec10' "LM Studio")" \
    "$(entry $'\uec10' "Ollama")" \
    "$(entry $'\ue739' "Ruby")" \
    "$(entry $'\ue719' "Node.js")" \
    "$(entry $'\ue76f' "Bun")" \
    "$(entry $'\ue7c0' "Deno")" \
    "$(entry $'\ue724' "Go")" \
    "$(entry $'\ue73d' "PHP")" \
    "$(entry $'\ue73f' "Laravel")" \
    "$(entry $'\ue757' "Symfony")" \
    "$(entry $'\ue73c' "Python")" \
    "$(entry $'\ue7cd' "Elixir")" \
    "$(entry $'\ue860' "Phoenix")" \
    "$(entry $'\ue7a8' "Rust")" \
    "$(entry $'\ue738' "Java")" \
    "$(entry $'\ue8ef' "Zig")" \
    "$(entry $'\ue77f' ".NET (dotnet)")" \
    "$(entry $'\ue84e' "OCaml")" \
    "$(entry $'\ue768' "Clojure")" \
    "$(entry $'\ue737' "Scala")" \
    "$(entry $'\ueb53' "Tailscale")" \
    "$(entry $'\ueb53' "WireGuard")" \
    "$(entry $'\ueb11' "Bitwarden")" \
    "$(entry $'\ueb53' "NordVPN")" \
    "$(entry $'\uf16b' "Dropbox")" \
