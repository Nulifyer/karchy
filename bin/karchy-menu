    "$(entry "󰌛" ".NET")" \
    "$(entry "󰘧" "OCaml")" \
    "$(entry "󰅩" "Clojure")" \
    "$(entry "󰘨" "Scala")" \
  ) in
  *Ruby*) present_terminal "karchy-remove-dev-env ruby" ;;
  *JavaScript*) show_remove_dev_js_menu ;;
  *Go) present_terminal "karchy-remove-dev-env go" ;;
  *PHP*) show_remove_dev_php_menu ;;
  *Python*) present_terminal "karchy-remove-dev-env python" ;;
  *Elixir*) show_remove_dev_elixir_menu ;;
  *Rust*) present_terminal "karchy-remove-dev-env rust" ;;
  *Java*) present_terminal "karchy-remove-dev-env java" ;;
  *Zig*) present_terminal "karchy-remove-dev-env zig" ;;
  *.NET*) present_terminal "karchy-remove-dev-env dotnet" ;;
  *OCaml*) present_terminal "karchy-remove-dev-env ocaml" ;;
  *Clojure*) present_terminal "karchy-remove-dev-env clojure" ;;
  *Scala*) present_terminal "karchy-remove-dev-env scala" ;;
  *) back_to show_remove_menu ;;
  esac
}

# ── Remove Menu ────────────────────────────────────────────────────────────
show_remove_menu() {
  case $(menu "Remove" \
    "$(entry "󰣇" "Package")" \
    "$(entry "󰖟" "Web App")" \
    "$(entry "󰅩" "Development")" \
  ) in
  *Package*) karchy-present-terminal karchy-pkg-remove 40 ;;
  *Web\ App*) present_terminal karchy-webapp-remove ;;
  *Development*) show_remove_dev_menu ;;
  *) back_to show_main_menu ;;
  esac
}

# ── System Menu ────────────────────────────────────────────────────────────
show_system_menu() {
  local entries=(
    "$(entry "󰌾" "Lock")"
    "$(entry "󰒲" "Suspend")"
  )

  # Add Hibernate if swap is available
  local swap_total
  swap_total=$(awk '/SwapTotal/{print $2}' /proc/meminfo)
  if (( swap_total > 0 )); then
    entries+=("$(entry "󰤄" "Hibernate")")
  fi

  entries+=(
    "$(entry "󰍃" "Logout")"
    "$(entry "󰜉" "Restart")"
    "$(entry "󰐥" "Shutdown")"
  )

  case $(menu "System" "${entries[@]}") in
  *Lock*) loginctl lock-session ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) qdbus6 org.kde.Shutdown /Shutdown logout ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ── Main Menu ──────────────────────────────────────────────────────────────
show_main_menu() {
  case $(menu "Karchy" \
    "$(entry "󰀻" "Apps")" \
    "$(entry "󰲋" "Projects")" \
    "$(entry "󰂺" "Learn")" \
    "$(entry "󰒓" "Setup")" \
    "$(entry "󰉉" "Install")" \
    "$(entry "󰆍" "Remove")" \
    "$(entry "󰚰" "Update")" \
    "$(entry "󰌢" "System")" \
  ) in
  *Apps*) fuzzel_apps ;;
  *Projects*) present_terminal karchy-project-open ;;
  *Learn*) show_learn_menu ;;
  *Setup*) show_setup_menu ;;
  *Install*) show_install_menu ;;
  *Remove*) show_remove_menu ;;
  *Update*) show_update_menu ;;
  *System*) show_system_menu ;;
  esac
}

# ── Entry point ────────────────────────────────────────────────────────────
if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  case "${1,,}" in
    apps) fuzzel_apps ;;
    learn) show_learn_menu ;;
    update) show_update_menu ;;
    setup) show_setup_menu ;;
    install) show_install_menu ;;
    remove) show_remove_menu ;;
    system) show_system_menu ;;
    *) show_main_menu ;;
  esac
else
  show_main_menu
fi
