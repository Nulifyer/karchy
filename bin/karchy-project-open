#!/bin/bash
# Browse and open discovered projects in a code editor.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/karchy-colors"

PROJECTS_DIR="$HOME/.local/share/applications/karchy-projects"
EDITOR_FILE="$HOME/.config/karchy/editor"
KNOWN_EDITORS=(cursor code zed helix sublime_text nvim vim)

# ── Editor helpers ────────────────────────────────────────────────────────────
get_installed_editors() {
  for e in "${KNOWN_EDITORS[@]}"; do
    command -v "$e" &>/dev/null && echo "$e"
  done
}

get_preferred_editor() {
  if [[ -f "$EDITOR_FILE" ]]; then
    local saved
    saved=$(<"$EDITOR_FILE")
    saved="${saved%"${saved##*[![:space:]]}"}"  # trim
    if [[ -n "$saved" ]] && command -v "$saved" &>/dev/null; then
      echo "$saved"
      return
    fi
  fi
  get_installed_editors | head -1
}

select_editor() {
  local installed current entries=() pick
  mapfile -t installed < <(get_installed_editors)
  if [[ ${#installed[@]} -eq 0 ]]; then
    echo "No supported editors found."
    return
  fi
  current=$(get_preferred_editor)
  for e in "${installed[@]}"; do
    if [[ "$e" == "$current" ]]; then
      entries+=("$e (current)")
    else
      entries+=("$e")
    fi
  done
  local fzf_colors
  fzf_colors=$(get_fzf_color_string)
  pick=$(printf '%s\n' "${entries[@]}" | fzf \
    --prompt "Editor > " \
    --color "$fzf_colors" \
    --layout reverse --border rounded --no-info)
  if [[ -n "$pick" ]]; then
    local editor="${pick% (current)}"
    mkdir -p "$(dirname "$EDITOR_FILE")"
    echo "$editor" > "$EDITOR_FILE"
  fi
}

# ── Auto-scan if no projects found yet ────────────────────────────────────────
if [[ ! -d "$PROJECTS_DIR" ]] || [[ -z "$(ls -A "$PROJECTS_DIR" 2>/dev/null)" ]]; then
  "$SCRIPT_DIR/karchy-project-scan"
fi

# ── Main loop ─────────────────────────────────────────────────────────────────
while true; do
  entries=()
  while IFS= read -r desktop; do
    name=$(grep -oP '^Name=\K.*' "$desktop")
    path=$(grep -oP '^Comment=\K.*' "$desktop")
    [[ -n "$name" && -n "$path" && -d "$path" ]] && entries+=("$name | $path")
  done < <(find "$PROJECTS_DIR" -name '*.desktop' -print 2>/dev/null | sort)

  if [[ ${#entries[@]} -eq 0 ]]; then
    echo "No projects found. Run karchy-project-scan first."
    exit 0
  fi

  current_editor=$(get_preferred_editor)
  editor_label="${current_editor:-none}"
  fzf_colors=$(get_fzf_color_string)

  result=$(printf '%s\n' "${entries[@]}" | fzf \
    --prompt "Project > " \
    --color "$fzf_colors" \
    --header "ctrl-r: rescan | ctrl-e: editor ($editor_label)" \
    --layout reverse --no-border --no-info \
    --expect "ctrl-r,ctrl-e")

  key=$(head -1 <<< "$result")
  selection=$(sed -n '2p' <<< "$result")

  if [[ "$key" == "ctrl-r" ]]; then
    "$SCRIPT_DIR/karchy-project-scan"
    continue
  fi

  if [[ "$key" == "ctrl-e" ]]; then
    select_editor
    continue
  fi

  [[ -z "$selection" ]] && exit 130

  project_path="${selection##* | }"

  editor=$(get_preferred_editor)
  if [[ -n "$editor" ]]; then
    karchy-detach "$editor" "$project_path"
    exit 130
  fi

  karchy-detach xdg-open "$project_path"
  exit 130
done
