#!/bin/bash
echo -e '\e[32mInstalling PHP and Laravel...\e[0m'
karchy-pkg-add php composer php-sqlite xdebug nodejs npm

if [[ :$PATH: != *:$HOME/.config/composer/vendor/bin:* ]]; then
  echo 'export PATH="$HOME/.config/composer/vendor/bin:$PATH"' >>"$HOME/.bashrc"
  source "$HOME/.bashrc"
  echo 'Added Composer global bin directory to PATH.'
fi

sudo sed -i \
  -e 's/^;zend_extension=xdebug.so/zend_extension=xdebug.so/' \
  -e 's/^;xdebug.mode=debug/xdebug.mode=debug/' \
  /etc/php/conf.d/xdebug.ini

for ext in bcmath intl iconv openssl pdo_sqlite pdo_mysql; do
  sudo sed -i "s/^;extension=${ext}/extension=${ext}/" /etc/php/php.ini
done

composer global require laravel/installer
echo -e '\nYou can now run: laravel new myproject'
