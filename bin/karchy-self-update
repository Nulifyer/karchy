#!/bin/bash
# Update karchy to the latest version from GitHub.

REPO_URL="https://github.com/Nulifyer/karchy.git"
CACHE_DIR="$HOME/.cache/karchy"

echo -e '\e[32mUpdating karchy...\e[0m'

if [[ -d "$CACHE_DIR/.git" ]]; then
  git -C "$CACHE_DIR" pull --ff-only
else
  rm -rf "$CACHE_DIR"
  git clone "$REPO_URL" "$CACHE_DIR"
fi

bash "$CACHE_DIR/install.sh"

echo ""
echo "karchy updated to latest version."
