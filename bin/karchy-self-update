#!/bin/bash
# Update karchy to the latest version.

INSTALL_DIR="$HOME/.local/share/karchy"

if [[ ! -d "$INSTALL_DIR/.git" ]]; then
  echo "Karchy install directory not found at $INSTALL_DIR"
  echo "Run the installer first."
  exit 1
fi

echo -e '\e[32mUpdating karchy...\e[0m'
git -C "$INSTALL_DIR" pull --ff-only

echo ""
echo "karchy updated to latest version."
